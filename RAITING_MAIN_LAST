<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MTBank - Global Ranking</title>
    <style>
        :root {
            --mtb-blue: #003d7c;
            --mtb-red: #e30613;
            --mtb-white: #ffffff;
            --mtb-bg: #f4f7f9;
            /* Приглушенные металлы */
            --gold-bg: rgba(255, 215, 0, 0.15);
            --silver-bg: rgba(192, 192, 192, 0.2);
            --bronze-bg: rgba(205, 127, 50, 0.15);
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body {
            margin: 0; padding: 0;
            font-family: 'Courier New', Courier, monospace;
            background-color: #001a33;
            display: flex; justify-content: center;
            height: 100vh; overflow: hidden;
        }

        .phone-container {
            width: 100%; max-width: 480px;
            background-color: var(--mtb-bg);
            height: 100%; display: flex;
            flex-direction: column; position: relative;
            border: 4px solid var(--mtb-blue);
        }

        /* HEADER */
        .header {
            background: var(--mtb-red);
            padding: 10px; display: flex;
            justify-content: space-around;
            border-bottom: 4px solid var(--mtb-blue);
        }

        .status-item {
            background: var(--mtb-white); color: var(--mtb-blue);
            padding: 5px 10px; border: 2px solid var(--mtb-blue);
            font-size: 14px; font-weight: bold;
            box-shadow: 2px 2px 0px var(--mtb-blue);
        }

        /* РЕЙТИНГОВАЯ ЗОНА */
        .ranking-content {
            flex: 1;
            padding: 15px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
        }

        .sticky-title {
            background: var(--mtb-blue);
            color: white; padding: 20px;
            text-align: center; font-weight: bold;
            border: 3px solid black;
            box-shadow: 4px 4px 0px var(--mtb-red);
            margin-bottom: 20px;
            font-size: 25px;
        }

        /* ТАБЛИЦА */
        .leaderboard {
            width: 100%;
            border-collapse: collapse;
        }

        .player-row {
            display: flex;
            align-items: center;
            padding: 12px 10px;
            border: 2px solid var(--mtb-blue);
            margin-bottom: 8px;
            background: white;
            box-shadow: 3px 3px 0px var(--mtb-blue);
        }

        /* Подиумные места */
        .player-row.rank-1 { background-color: var(--gold-bg); border-color: #b8860b; }
        .player-row.rank-2 { background-color: var(--silver-bg); border-color: #808080; }
        .player-row.rank-3 { background-color: var(--bronze-bg); border-color: #8b4513; }

        
        .player-info {
            flex: 1;
        }
        .player-name {
            display: block; 
            font-size: 18px; 
            font-weight: 900; /* Максимальная жирность */
            text-transform: uppercase;
            letter-spacing: 0.5px;
            color: var(--mtb-blue);
        }

        .player-score {
            font-weight: 900; /* Максимальная жирность */
            font-size: 16px; 
            color: var(--mtb-red);
            white-space: nowrap;
        }

        .rank-num {
            width: 45px; 
            font-size: 20px; 
            font-weight: 900;
            color: var(--mtb-blue);
            opacity: 0.8;
        }

        /* МОЁ МЕСТО (FIXED BOTTOM) */
        .my-status-box {
            background: var(--mtb-blue);
            padding: 15px;
            border-top: 4px solid var(--mtb-red);
            color: white;
        }

        .my-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            border: 2px dashed white;
            padding: 10px;
            margin-bottom: 20px;
        }

        /* КНОПКА ЗАРАБОТАТЬ */
        .earn-btn {
            display: block;
            width: 100%;
            background: var(--mtb-red);
            color: white;
            text-align: center;
            text-decoration: none;
            padding: 15px;
            margin-top: 15px;
            font-weight: 900;
            font-size: 20px;
            border: 3px solid #fff;
            box-shadow: 4px 4px 0px var(--mtb-blue);
            transition: 0.1s;
        }

        .earn-btn:active {
            transform: translate(2px, 2px);
            box-shadow: 1px 1px 0px var(--mtb-blue);
            border:3px solid #000;
        }

        /* NAVIGATION BOTTOM (Consistent with main) */
        .bottom-nav {
            background: var(--mtb-blue);
            display: flex; justify-content: space-evenly;
            padding: 10px 0 20px 0; border-top: 4px solid var(--mtb-red);
        }
        .nav-icon { font-size: 24px; color: white; opacity: 0.5; }
        .nav-icon.active { opacity: 1; filter: drop-shadow(2px 2px 0px var(--mtb-red)); }

    </style>
</head>
