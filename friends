<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MTBank - Friends Database</title>
    <style>
        :root {
            --mtb-blue: #003d7c;
            --mtb-red: #e30613;
            --mtb-white: #ffffff;
            --mtb-bg: #f4f7f9;
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body {
            margin: 0; padding: 0;
            font-family: 'Courier New', Courier, monospace;
            background-color: #001a33;
            display: flex; justify-content: center;
            height: 100vh; overflow: hidden;
        }

        .phone-container {
            width: 100%; max-width: 480px;
            background-color: var(--mtb-bg);
            height: 100%; display: flex;
            flex-direction: column; position: relative;
            border: 4px solid var(--mtb-blue);
        }

        /* HEADER */
        .header {
            background: var(--mtb-red);
            padding: 10px; display: flex;
            justify-content: space-around;
            border-bottom: 4px solid var(--mtb-blue);
        }

        .status-item {
            background: var(--mtb-white); color: var(--mtb-blue);
            padding: 5px 10px; border: 2px solid var(--mtb-blue);
            font-size: 14px; font-weight: bold;
            box-shadow: 2px 2px 0px var(--mtb-blue);
        }

        /* КОНТЕНТ */
        .friends-content {
            flex: 1;
            padding: 20px;
            overflow-y: auto;
        }

        .sticky-title {
            background: var(--mtb-blue);
            color: white; padding: 10px;
            text-align: center; font-weight: bold;
            border: 3px solid black;
            box-shadow: 4px 4px 0px var(--mtb-red);
            margin-bottom: 25px;
        }

        /* СПИСОК ДРУЗЕЙ */
        .friends-list {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .friend-card {
            position: relative; /* ДЛЯ ПОЗИЦИОНИРОВАНИЯ ПОДСКАЗКИ */
            display: flex;
            align-items: center;
            background: white;
            border: 3px solid var(--mtb-blue);
            padding: 12px;
            box-shadow: 4px 4px 0px var(--mtb-blue);
            cursor: pointer;
            transition: 0.2s;
        }

        .friend-avatar {
            width: 45px; height: 45px;
            background: #ddd;
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 24px; margin-right: 15px;
        }

        .friend-main-info {
            flex: 1;
        }

        .friend-name {
            display: block; font-weight: 900; font-size: 22px;
            color: var(--mtb-blue); text-transform: uppercase;
        }

        .friend-tokens {
            font-weight: 900; font-size: 20px; color: var(--mtb-red);
        }

        /* ВСПЛЫВАЮЩАЯ ПОДСКАЗКА (TOOLTIP) */
        .friend-tooltip {
            position: absolute;
            top: 100%; /* Появляется СНИЗУ карточки */
            left: 50%;
            transform: translateX(-50%);
            width: 95%; /* Чуть шире для удобства */
            background: var(--mtb-blue);
            color: white;
            padding: 15px;
            border: 3px solid black;
            box-shadow: 6px 6px 0px var(--mtb-red);
            z-index: 1000; /* Очень высокий индекс, чтобы быть над другими карточками */
            
            /* Скрываем по умолчанию */
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            margin-top: 10px; /* Отступ от карточки */
        }

        /* Треугольник внизу подсказки */
        .friend-tooltip::after {
            content: '';
            position: absolute;
            bottom: 100%; /* Перемещаем на верхнюю грань подсказки */
            left: 50%;
            transform: translateX(-50%);
            border-left: 10px solid transparent;
            border-right: 10px solid transparent;
            border-bottom: 10px solid black; /* Стрелка указывает ВВЕРХ */
            border-top: none;
        }

        /* ЭФФЕКТ ПРИ НАВЕДЕНИИ */
        .friend-card:hover {
            z-index: 1100; /* Поднимаем саму карточку, чтобы подсказка была над всем остальным */
            transform: scale(1.02);
        }

        .friend-card:hover .friend-tooltip {
            opacity: 1;
            visibility: visible;
            top: 110%; /* Плавно опускается чуть ниже при появлении */
        }

        /* ИНФОРМАЦИЯ ВНУТРИ ПОДСКАЗКИ */
        .info-row {
            display: flex;
            justify-content: space-between;
            font-size: 14px; /* Увеличил, чтобы соответствовало твоему стилю */
            margin-bottom: 8px;
            border-bottom: 1px dashed rgba(255,255,255,0.4);
            padding-bottom: 4px;
        }
        .info-label { font-weight: bold; opacity: 0.9; text-transform: uppercase; }
        .info-val { font-weight: 900; color: #fff; }
        .info-row:last-child { border: none; }

        /* FOOTER NAV */
        .bottom-nav {
            background: var(--mtb-blue);
            display: flex; justify-content: space-evenly;
            padding: 10px 0 20px 0; border-top: 4px solid var(--mtb-red);
        }
        .nav-icon { font-size: 24px; color: white; opacity: 0.5; }
        .nav-icon.active { opacity: 1; filter: drop-shadow(2px 2px 0px var(--mtb-red)); }

        /* БЛОК ДЕЙСТВИЯ (НИЖНЯЯ ПАНЕЛЬ) */
        .invite-action-box {
            margin-top: 185px;
            background: var(--mtb-blue);
            padding: 15px 25px;
            border: 4px solid var(--mtb-red);
            z-index: 10; /* Чтобы быть поверх списка при скролле */
        }

        .referral-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            border: 2px dashed white;
            padding: 8px 12px;
            margin-bottom: 15px;
            color: white;
        }

        .ref-label { font-size: 10px; font-weight: bold; opacity: 0.8; }
        .ref-bonus { font-size: 14px; font-weight: 900; color: #00ff00; } /* Зеленый акцент на награде */

        /* СТИЛИ КНОПКИ (КОПИЯ С РЕЙТИНГА) */
        .invite-btn {
            display: block;
            width: 100%;
            background: var(--mtb-red);
            color: white;
            text-align: center;
            text-decoration: none;
            padding: 15px;
            font-weight: 900;
            font-size: 18px; /* Чуть увеличил для жирности */
            text-transform: uppercase;
            border: 3px solid black;
            box-shadow: 4px 4px 0px #000; /* Жесткая черная тень для ретро */
            transition: 0.1s;
        }

        .invite-btn:active {
            transform: translate(2px, 2px);
            box-shadow: 1px 1px 0px #000;
            background-color: #af0712;
        }
    </style>
</head>
