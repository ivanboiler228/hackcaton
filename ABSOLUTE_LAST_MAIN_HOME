<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>MTBank Retro Super App</title>
    
    <style>
        :root {
            --mtb-blue: #003d7c;
            --mtb-red: #e30613;
            --mtb-white: #ffffff;
            --mtb-bg: #f4f7f9;
            --retro-shadow: 4px 4px 0px var(--mtb-blue);
        }

        * { box-sizing: border-box; -webkit-tap-highlight-color: transparent; }

        body {
            margin: 0; padding: 0;
            font-family: 'Courier New', Courier, monospace; /* Ретро-шрифт */
            background-color: #001a33; 
            display: flex; justify-content: center;
            height: 100vh; overflow: hidden;
        }

        .phone-container {
            width: 100%; max-width: 480px;
            background-color: var(--mtb-bg);
            height: 100%; display: flex;
            flex-direction: column; position: relative;
            border: 4px solid var(--mtb-blue);
        }

        /* HEADER */
        .header {
            background: var(--mtb-red);
            padding: 10px; display: flex;
            justify-content: space-around; z-index: 1000;
            border-bottom: 4px solid var(--mtb-blue);
        }

        .status-item {
            background: var(--mtb-white); color: var(--mtb-blue);
            padding: 5px 10px; border: 2px solid var(--mtb-blue);
            font-size: 14px; font-weight: bold;
            box-shadow: 2px 2px 0px var(--mtb-blue);
        }

        /* СКРОЛЛ-ЗОНА */
        .main-scroll-area {
            flex: 1;
            overflow-y: auto;
            scroll-behavior: smooth;
        }

        

        .room-container {
            display: flex;
            justify-content: center;
            align-items: center;
            width: 100%; height: 350px;
        }
        .room-container iframe { width: 100%; height: 100%; border: none; }

        /* САЙДБАР ТРАНСФОРМЕР */
        .sidebar-right {
            position: fixed; right: 15px; top: 50%;
            transform: translateY(-50%);
            display: flex; flex-direction: column; gap: 10px;
            z-index: 500; transition: all 0.4s steps(4); /* Шаговая анимация для ретро-эффекта */
        }

        .side-item {
            background: white; border: 3px solid var(--mtb-blue);
            width: 50px; height: 50px; border-radius: 0; /* Квадратные кнопки */
            display: flex; align-items: center; justify-content: center;
            text-decoration: none; font-size: 20px;
            box-shadow: 4px 4px 0px var(--mtb-blue);
        }

        .side-item:active { transform: translate(2px, 2px); box-shadow: 2px 2px 0px var(--mtb-blue); }

        .side-text { display: block; font-size: 8px; font-weight: bold; position: absolute; bottom: -12px; color: var(--mtb-blue); }

        /* Компактный режим сайдбара */
        .sidebar-right.compact { top: 120px; transform: translateY(0); }
        .sidebar-right.compact .hide-on-scroll { display: none; }

        /* STICKY ЗАГОЛОВКИ */
        .sticky-title {
            position: sticky; top: -1px;
            background: var(--mtb-blue); color: white;
            padding: 10px; font-size: 20px; font-weight: bold;
            border-top: 4px solid var(--mtb-red);
            z-index: 900; text-align: center;
            margin-top: 5px;
        }

        /* МАГАЗИН: СЕТКА ТОВАРОВ */
        .shop-grid {
            display: grid; grid-template-columns: 1fr 1fr;
            gap: 15px; padding: 20px; background: #ddd;
        }

        .shop-item {
            background: white; border: 3px solid var(--mtb-blue);
            padding: 10px; display: flex; flex-direction: column;
            align-items: center; box-shadow: 4px 4px 0px #888;
        }

        .item-img { font-size: 40px; margin-bottom: 10px; }
        .item-name { font-size: 12px; font-weight: bold; text-align: center; height: 30px; }
        .item-price { color: var(--mtb-red); font-weight: 900; margin: 10px 0; }

        .buy-btn {
            width: 100%; background: var(--mtb-blue); color: white;
            border: none; padding: 8px; font-family: inherit;
            font-weight: bold; cursor: pointer; border: 2px solid black;
        }

        /* Недоступный товар */
        .shop-item.locked { opacity: 0.6; filter: grayscale(1); }
        .shop-item.locked .buy-btn { background: #666; cursor: not-allowed; }

        

    /* Стили уровня */
    .level-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .lvl-label { font-weight: bold; font-size: 18px; padding: 10px 20px; }
    .lvl-num { 
        font-size: 24px; 
        background: var(--mtb-blue); 
        color: white; 
        padding: 0 10px;
    }

    .xp-container {
        height: 20px;
        background: #eee;
        border: 2px solid var(--mtb-blue);
        position: relative;
        overflow: hidden;
    }
    .xp-bar {
        height: 100%;
        background: var(--mtb-red);
        border-right: 2px solid var(--mtb-blue);
    }

    .xp-details {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: space-between;
        font-size: 15px;
        font-weight: bold;
        padding: 13px 10px;
    }

    /* Тренды (Стрелочки) */
    .trend { font-size: 15px; margin-top: 5px; font-weight: bold; }
    .trend.up { color: green; }
    .trend.down { color: var(--mtb-red); }

    /* История логов */
    .history-header {
        background: var(--mtb-blue);
        color: white;
        padding: 5px;
        font-size: 12px;
        margin-bottom: 10px;
        text-align: center;
    }

    .history-scroll {
        max-height: 200px;
        overflow-y: auto;
    }

    .history-row {
        display: flex;
        justify-content: space-between;
        font-size: 15px;
        padding: 8px 0;
        border-bottom: 1px dashed var(--mtb-blue);
    }

    .h-date { color: #888; width: 40px; margin-left: 10px;}
    .h-name { font-size: 15px; flex: 1; text-transform: uppercase; padding: 0 5px; margin:0 10px; }
    .h-price { font-weight: bold; }
    .h-price.plus { color: green; }
    .h-price.minus { color: var(--mtb-red); }
    .h-price.bank { color: var(--mtb-blue); }

    /* Анимация мигания текста */
    .blink-text {
        animation: blink 1s steps(2) infinite;
    }
    @keyframes blink {
        from { visibility: visible; }
        to { visibility: hidden; }
    }

    .finance-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 20px;
        padding: 10px 10px;
    }
        /* FOOTER */
        .bottom-nav {
            background: var(--mtb-blue); border-top: 4px solid var(--mtb-red);
            display: flex; justify-content: space-evenly; padding: 10px 0 20px 0;
        }
        .nav-icon { font-size: 24px; color: white;  }
        

        /* ПОЧТА */
        /* СТИЛИ ДЛЯ РЕТРО-ПОЧТЫ */

.section-mail {
    padding: 20px;
    background: var(--mtb-bg);
}

.email-profile {
    background: var(--mtb-blue);
    color: white;
    padding: 15px;
    border: 3px solid black;
    box-shadow: 6px 6px 0px var(--mtb-red);
    margin-bottom: 25px;
}

.email-profile label {
    font-size: 9px;
    font-weight: bold;
    letter-spacing: 1px;
    opacity: 0.8;
}

.email-profile .email-val {
    font-size: 16px;
    font-weight: 900;
    margin-top: 5px;
    word-break: break-all;
}

/* Карточки писем */
.mail-card {
    background: white;
    border: 3px solid var(--mtb-blue);
    padding: 12px;
    margin-bottom: 12px;
    display: flex;
    gap: 12px;
    align-items: center;
    box-shadow: 4px 4px 0px var(--mtb-blue);
    position: relative;
    transition: 0.1s;
}

.mail-card.unread {
    border-left: 10px solid var(--mtb-red); /* Акцент на непрочитанном */
}

.mail-card:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0px var(--mtb-blue);
}

.mail-icon {
    font-size: 24px;
    filter: drop-shadow(2px 2px 0px #eee);
}

.mail-text {
    flex: 1;
}

.mail-title {
    display: block;
    font-weight: 900;
    font-size: 13px;
    color: var(--mtb-blue);
    margin-bottom: 3px;
    text-transform: uppercase;
}

.mail-desc {
    display: block;
    font-size: 10px;
    color: #444;
    line-height: 1.2;
}

.mail-time {
    font-size: 9px;
    font-weight: bold;
    color: #888;
    align-self: flex-start;
}

/* Переиспользуем заголовок из Инфо для единства стиля */
.history-header {
    background: var(--mtb-blue);
    color: white;
    padding: 10px;
    font-size: 20px;
    font-weight: bold;
    margin-bottom: 10px;
    text-align: center;
    border-top: 4px solid #e30613;
}

.fin-card{
    text-align: center;
}
/* СЕКЦИЯ: ДОМ */
        .section-home {
