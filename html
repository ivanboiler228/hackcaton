<script>
    (function() {

        let balance = 1000;
        let level = 5;
        let energy = 5;
        let currentPos = 0;
        let isSpinning = false;
        let secondsToRegen = 1200;
        let currentProduct = "";
        let xp = 1250;
        let xpNextLvl = 10000;

        const shopData = {
            'cactus': {
                name: "ЗОЛОТОЙ КАКТУС",
                desc: "Эксклюзивный декор. Приносит удачу и символизирует рост активов МТБанка!",
                price: 500,
                image: "https://i.pinimg.com/736x/e3/15/3e/e3153e12324ff09c4e2afffa328c7c1c.jpg",
                roomImg: "https://i.pinimg.com/736x/13/8e/b4/138eb4e7ad67432a2e7f11fd85fcf17c.jpg"
            },
            'map': {
                name: "КАРТА МИРА",
                desc: "Открывает новые горизонты планирования бюджета и кэшбэка по всему миру!",
                price: 600,
                image: "https://i.pinimg.com/736x/2a/af/1a/2aaf1a1ede7a2fe27d2f4b28f448cac2.jpg",
                roomImg: "https://i.pinimg.com/736x/b6/e5/38/b6e53869e0a5eb9a3bf3c413b3c3eba7.jpg"
            }
        };
        const tokensDisplay = document.getElementById('tokens-display');
        const levelDisplay = document.getElementById('level-display');
        const energyDisplay = document.getElementById('energy-display');
        const balanceInline = document.getElementById('balance-inline');
        const energyCountSpan = document.getElementById('energy-count');
        const energyTimerDiv = document.getElementById('energy-timer');
        const infoLevel = document.getElementById('info-level');
        const xpBar = document.getElementById('xp-bar-fill');
        const xpText = document.getElementById('xp-text');
        const myRankTokens = document.getElementById('my-rank-tokens');
        const sidebar = document.getElementById('sidebar');
        const tabHome = document.getElementById('tab-home');
        const playerSpriteUrl = "https://i.postimg.cc/zByYBNm6/cel.png"; 

        function updateAllDisplays() {
            if (tokensDisplay) tokensDisplay.textContent = `🪙 ${balance}`;
            if (levelDisplay) levelDisplay.textContent = `⭐️ LVL ${level.toString().padStart(2, '0')}`;
            if (energyDisplay) energyDisplay.textContent = `⚡️ ${energy}/5`;

            document.querySelectorAll('.balance-val').forEach(el => {
                el.textContent = balance;
            });
            document.querySelectorAll('.lvl-val').forEach(el => {
                el.textContent = level.toString().padStart(2, '0');
            });
            if (xpBar) {
                const xpPercent = (xp / xpNextLvl) * 100;
                xpBar.style.width = `${xpPercent}%`;
            }
            if (xpText) {
                xpText.textContent = `XP: ${xp} / ${xpNextLvl}`;
            }
            if (balanceInline) balanceInline.textContent = `${balance} 🪙`;
            if (energyCountSpan) energyCountSpan.textContent = energy;
            if (infoLevel) infoLevel.textContent = level.toString().padStart(2, '0');
            if (myRankTokens) myRankTokens.textContent = `${balance} 🪙`;
        }

        window.buyItem = function(price) {
            if (balance >= price) {
                balance -= price;
                updateAllDisplays();
                alert('✅ Покупка совершена!');
            } else {
                alert('❌ Недостаточно токенов!');
            }
        };
       
function showFinanceHelp() {
    document.getElementById('finance-help-modal').style.display = 'flex';
}

function closeFinanceHelp() {
    document.getElementById('finance-help-modal').style.display = 'none';
}


        function openShopModal(itemId) {
            const item = shopData[itemId];
            if (item) {
                currentProduct = itemId;
                document.getElementById('modal-item-name').innerText = item.name;
                document.getElementById('modal-item-desc').innerText = item.desc;
                document.getElementById('modal-item-price').innerText = `${item.price} 🪙`;
                document.getElementById('modal-item-pic').src = item.image;
                document.getElementById('shop-modal').style.display = 'flex';
                const confirmBtn = document.getElementById('buy-confirm-btn');
                confirmBtn.onclick = () => confirmPurchase(itemId);
            }
        }

        function closeShopModal() {
            document.getElementById('shop-modal').style.display = 'none';
        }

        function confirmPurchase(itemId) {
            const item = shopData[itemId];

            if (balance >= item.price) {
                balance -= item.price;

                const roomImg = document.getElementById('roomImage');
                roomImg.src = item.roomImg;

                addLogEntry(`КУПЛЕН_${item.name}`, item.price, 'minus');

                updateAllDisplays();

                alert(`🎉 УСПЕХ! ${item.name} теперь в твоей комнате.`);
                closeShopModal();

                const shopItem = document.getElementById(`item-${itemId}`);
                if (shopItem) shopItem.classList.add('locked');

            } else {
                alert("❌ НЕДОСТАТОЧНО ТОКЕНОВ! Нужно больше кэшбэка.");
            }
        }

        window.onload = () => {
            updateAllDisplays();
            addLogEntry("КЭШБЭК_ЗА_КОФЕ", 50, "plus");
            addLogEntry("MTB_ТРАНЗАКЦИЯ:_VARKA", 4.50, "bank");
        };

        function switchTab(tabId) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.getElementById(`tab-${tabId}`).classList.add('active');
            document.querySelectorAll('.nav-item').forEach(item => {
                item.classList.toggle('active', item.dataset.tab === tabId);
            });
            if (sidebar) sidebar.style.display = (tabId === 'game') ? 'none' : 'flex';
            if (tabId === 'stonks') fetchRates();
        }
        document.querySelectorAll('.nav-item[data-tab]').forEach(item => {
            item.addEventListener('click', (e) => switchTab(item.dataset.tab));
        });
        if (tabHome && sidebar) {
            tabHome.addEventListener('scroll', () => {
                sidebar.classList.toggle('compact', tabHome.scrollTop > 50);
            });
        }
        async function fetchRates() {
            try {
                const ids = [431, 451, 456];
                const tableBody = document.getElementById('rates-table');
                tableBody.innerHTML = '';
                for (let id of ids) {
                    const response = await fetch(`https://www.nbrb.by/api/exrates/rates/${id}`);
                    const data = await response.json();
                    tableBody.innerHTML += `<tr>
                        <td class="currency-name">${data.Cur_Abbreviation} (${data.Cur_Scale})</td>
                        <td class="currency-val">${data.Cur_OfficialRate.toFixed(4)} BYN</td>
                    </tr>`;
                }
                document.getElementById('update-time').innerText = `ПОСЛЕДНЕЕ ОБНОВЛЕНИЕ: ${new Date().toLocaleTimeString()}`;
            } catch (error) {
                document.getElementById('rates-table').innerHTML = '<tr><td colspan="2" style="color:red">ОШИБКА ПОЛУЧЕНИЯ ДАННЫХ</td></tr>';
            }
        }
        function addLogEntry(name, amount, type) {
            const container = document.getElementById('history-log-container');
            if (!container) return;

            const date = new Date().toLocaleDateString('ru-RU', { day: '2-digit', month: '2-digit' });

            let amountStr = amount;
            if (type === 'minus') amountStr = `-${amount} 🪙`;
            else if (type === 'plus') amountStr = `+${amount} 🪙`;
            else amountStr = `${amount} BYN`;

            const newRow = document.createElement('div');
            newRow.className = 'history-row';
            newRow.innerHTML = `
                <span class="h-date">${date}</span>
                <span class="h-name">${name}</span>
                <span class="h-price ${type}">${amountStr}</span>
            `;
            container.prepend(newRow);
        }

        const bankQuestions = [
            { q: "Что такое грейс-период по карте Халва?", options:["Штраф за просрочку", "Период без процентов", "Плата за обслуживание"], correct: 1, reward: 50 },
            { q: "В какой валюте выгоднее хранить подушку безопасности?", options:["В криптовалюте", "В разных валютах", "Только в рублях"], correct: 1, reward: 30 },
            { q: "Что делает капитализация процентов?", options:["Сжигает деньги", "Начисляет проценты на проценты", "Уменьшает ставку"], correct: 1, reward: 100 }
        ];

        function showQuestion() {
            const randomQ = bankQuestions[Math.floor(Math.random() * bankQuestions.length)];
            document.getElementById('quiz-question').textContent = randomQ.q;
            const optionsContainer = document.getElementById('quiz-options');
            optionsContainer.innerHTML = '';
            randomQ.options.forEach((optText, index) => {
                const btn = document.createElement('button');
                btn.className = 'option-btn';
                btn.textContent = optText;
                btn.onclick = () => checkAnswer(btn, index, randomQ.correct, randomQ.reward);
                optionsContainer.appendChild(btn);
            });
            document.getElementById('quiz-modal').style.display = 'flex';
        }

        function checkAnswer(clickedBtn, selectedIndex, correctIndex, reward) {
            const allBtns = document.querySelectorAll('#quiz-options .option-btn');
            allBtns.forEach(b => b.disabled = true);
            if (selectedIndex === correctIndex) {
                clickedBtn.classList.add('correct');
                balance += reward;
                updateAllDisplays();
                setTimeout(() => document.getElementById('quiz-modal').style.display = 'none', 1000);
            } else {
                clickedBtn.classList.add('wrong');
                allBtns[correctIndex].classList.add('correct');
                balance -= reward/2;
                if (balance < 0) balance = 0;
                updateAllDisplays();
                setTimeout(() => document.getElementById('quiz-modal').style.display = 'none', 1500);
            }
        }

        function spinWheel() {
            if (isSpinning) return;
            isSpinning = true;
            const spinBtn = document.getElementById('spin-btn');
            spinBtn.disabled = true;
            spinBtn.style.opacity = "0.5";

            const rand = Math.random() * 100;
            let sectorIndex;
            if (rand < 2) sectorIndex = 4;
            else if (rand < 15) sectorIndex = 3;
            else if (rand < 40) sectorIndex = 2;
            else if (rand < 70) sectorIndex = 1;
            else sectorIndex = 0;

            const startAngle = sectorIndex * 72;
            const finalRotation = 3600 + (360 - startAngle);
            const wheel = document.getElementById('wheel');
            wheel.style.transition = 'transform 4s cubic-bezier(0.15, 0, 0.15, 1)';
            wheel.style.transform = `rotate(${finalRotation}deg)`;

            setTimeout(() => {
                const rewards = [10, 20, 30, 50, 100];
                balance += rewards[sectorIndex];
                updateAllDisplays();
                alert(`🎉 Поздравляем! Ваш приз: ${rewards[sectorIndex]} 🪙`);
                isSpinning = false;
                spinBtn.disabled = false;
                spinBtn.style.opacity = "1";
                document.getElementById('wheel-modal').style.display = 'none';
                wheel.style.transition = 'none';
                wheel.style.transform = 'rotate(0deg)';
            }, 4500);
        }
        window.spinWheel = spinWheel;
        window.openShopModal = openShopModal;
        window.closeShopModal = closeShopModal;
        window.switchTab = switchTab;
        window.showFinanceHelp = showFinanceHelp;
        window.closeFinanceHelp = closeFinanceHelp;

        const cols = 4;
        const step = 70;
        const boardContainer = document.getElementById('board-container');

        function getTilePosition(index) {
            const cycle = Math.floor(index / 12);
            const rem = index % 12;
            let col = 0;
            let row = cycle * 6;
            if (rem < 4) { col = rem; row += 0; }
            else if (rem < 6) { col = 3; row += (rem - 3); }
            else if (rem < 10) { col = 9 - rem; row += 3; }
            else { col = 0; row += (rem - 6); }
            return { col, row };
        }

        function initBoard() {
    if (!boardContainer) return;
    boardContainer.innerHTML = `<div id="player-token"><img src="${playerSpriteUrl}" class="player-sprite"></div>`;
    const iconGame = "https://i.pinimg.com/736x/b8/94/f5/b894f5ec29159c427f3ac1d9eebc2bfd.jpg";
    const iconWheel = "https://i.pinimg.com/736x/69/99/a7/6999a7056739d74cb343ae09f50af849.jpg";
    const iconQuiz = "https://i.pinimg.com/736x/0e/b6/7c/0eb67c38bd9a08e3479a5885f8210aa8.jpg";

    for (let i = 0; i < 200; i++) {
        const tile = document.createElement('div');
        tile.className = 'board-tile';
        const rand = Math.random() * 100;

        if (i === 0) { 
            tile.innerText = 'GO'; 
            tile.style.background = '#2ecc71'; 
            tile.style.fontSize = '16px';
        }
        else if (rand < 15) { 
            tile.classList.add('jackpot');
            tile.innerHTML = `<img src="${iconGame}" class="tile-icon-img">`;
            tile.dataset.type = 'catch_game'; 
        }
        else if (rand < 40) { 
            tile.classList.add('chance'); 
            tile.innerHTML = `<img src="${iconWheel}" class="tile-icon-img">`;
            tile.dataset.type = 'wheel'; 
        }
        else { 
            tile.classList.add('quiz'); 
            tile.innerHTML = `<img src="${iconQuiz}" class="tile-icon-img">`;
            tile.dataset.type = 'quiz'; 
        }

        const pos = getTilePosition(i);
        tile.style.transform = `translate(${pos.col * step}px, ${-pos.row * step}px)`;
        boardContainer.appendChild(tile);
    }
    updateGameBoardPosition();
}

        function updateGameBoardPosition() {
            const pos = getTilePosition(currentPos);
            let px = pos.col * step;
            let py = -pos.row * step;
            const tiles = document.querySelectorAll('.board-tile');
            tiles.forEach((tile, index) => {
                if (index < currentPos) tile.classList.add('passed');
                else tile.classList.remove('passed');
            });
            const token = document.getElementById('player-token');
            if(token) {
                token.style.transform = `translate(${px}px, ${py - 30}px) scale(1.3)`;
                setTimeout(() => {
                    token.style.transform = `translate(${px}px, ${py}px) scale(1)`;
                }, 150);
            }
            let offsetY = Math.max(0, -py - 30);
            boardContainer.style.transform = `translateY(${offsetY}px)`;
        }

        function playTurn() {
            if (energy <= 0) { alert("Энергия на нуле! ⚡️ Жди таймер."); return; }
            const rollBtn = document.getElementById('roll-btn');
            const diceFace = document.getElementById('dice-face');
            rollBtn.disabled = true;
            diceFace.classList.add('shaking');
            let shuffles = 0;
            let finalRoll = 1;
            const diceChars = ['⚀', '⚁', '⚂', '⚃', '⚄', '⚅'];
            const rollInterval = setInterval(() => {
                finalRoll = Math.floor(Math.random() * 6) + 1;
                diceFace.innerText = diceChars[finalRoll - 1];
                shuffles++;
                if (shuffles > 18) {
                    clearInterval(rollInterval);
                    diceFace.classList.remove('shaking');
                    energy--;
                    updateAllDisplays();
                    setTimeout(() => {
                        let stepsTaken = 0;
                        const moveInterval = setInterval(() => {
                            currentPos++;
                            stepsTaken++;
                            updateGameBoardPosition();
                            if (stepsTaken >= finalRoll) {
                                clearInterval(moveInterval);
                                rollBtn.disabled = false;
                                setTimeout(checkTileEvent, 300);
                            }
                        }, 300);
                    }, 600);
                }
            }, 100);
        }

        function checkTileEvent() {
            const tiles = document.querySelectorAll('.board-tile');
            if (currentPos >= tiles.length) {
                alert('🏆 ФИНИШ! Ты прошел игру! +2000 🪙');
                balance += 2000;
                currentPos = 0;
                updateAllDisplays();
                updateGameBoardPosition();
                return;
            }
            const currentTile = tiles[currentPos];
            if(!currentTile) return;
            const type = currentTile.dataset.type;
            if (type === 'catch_game') {
                startCatchGame();
            } else if (type === 'wheel') {
                document.getElementById('wheel-modal').style.display = 'flex';
            } else if (type === 'quiz') {
                showQuestion();
            }
        }

        document.getElementById('roll-btn').addEventListener('click', playTurn);

        const catchModal = document.getElementById('catch-game-modal');
        const gameArea = document.getElementById('game-area');
        const basket = document.getElementById('basket');
        const timerDisplay = document.getElementById('game-timer');
        const scoreDisplay = document.getElementById('game-score');

        let gameScore = 0;
        let gameTimeLeft = 10;
        let gameInterval;
        let coinSpawnInterval;
        let isGameActive = false;

        function startCatchGame() {
            if (isGameActive) return;
            isGameActive = true;

            gameScore = 0;
            gameTimeLeft = 10;
            scoreDisplay.textContent = `СЧЕТ: ${gameScore}`;
            timerDisplay.textContent = `ВРЕМЯ: ${gameTimeLeft}с`;

            const oldCoins = gameArea.querySelectorAll('.coin');
            oldCoins.forEach(coin => coin.remove());

            basket.style.left = '50%';

            catchModal.style.display = 'flex';

            gameInterval = setInterval(updateGameTimer, 1000);
            coinSpawnInterval = setInterval(spawnCoin, 500);
        }

        function updateGameTimer() {
            gameTimeLeft--;
            timerDisplay.textContent = `ВРЕМЯ: ${gameTimeLeft}с`;

            if (gameTimeLeft <= 0) {
                endCatchGame();
            }
        }

        function spawnCoin() {
            if (!isGameActive) return;

            const coin = document.createElement('div');
            coin.className = 'coin';
            coin.textContent = '🪙';

            const areaWidth = gameArea.offsetWidth;
            const coinSize = 35;
            const randomX = Math.random() * (areaWidth - coinSize);

            coin.style.left = `${randomX}px`;

            const coinId = 'coin_' + Date.now() + Math.random();
            coin.id = coinId;

            gameArea.appendChild(coin);

            checkCollision(coin);

            setTimeout(() => {
                if (coin.parentNode === gameArea) {
                    gameArea.removeChild(coin);
                }
            }, 2100);
        }

        function checkCollision(coin) {
            if (!isGameActive) return;

            const collisionInterval = setInterval(() => {
                if (!isGameActive || !coin.parentNode) {
                    clearInterval(collisionInterval);
                    return;
                }

                const basketRect = basket.getBoundingClientRect();
                const coinRect = coin.getBoundingClientRect();

                if (
                    coinRect.bottom >= basketRect.top &&
                    coinRect.top <= basketRect.bottom &&
                    coinRect.right >= basketRect.left &&
                    coinRect.left <= basketRect.right
                ) {
                    gameScore += 10;
                    scoreDisplay.textContent = `СЧЕТ: ${gameScore}`;

                    if (coin.parentNode === gameArea) {
                        gameArea.removeChild(coin);
                    }
                    clearInterval(collisionInterval);

                    basket.style.boxShadow = '0 0 15px #f1c40f';
                    setTimeout(() => {
                        basket.style.boxShadow = '3px 3px 0 rgba(0,0,0,0.2)';
                    }, 150);
                }
            }, 50);
        }

        function endCatchGame() {
            isGameActive = false;
            clearInterval(gameInterval);
            clearInterval(coinSpawnInterval);

            balance += gameScore;
            updateAllDisplays();

            alert(`🎉 ИГРА ОКОНЧЕНА!\n\nТы поймал кэшбэка на ${gameScore} 🪙!`);

            catchModal.style.display = 'none';
        }

        gameArea.addEventListener('touchmove', function(e) {
            if (!isGameActive) return;

            e.preventDefault();

            const touch = e.touches[0];

            const areaRect = gameArea.getBoundingClientRect();

            let touchX = touch.clientX - areaRect.left;

            const basketWidth = basket.offsetWidth;
            if (touchX < basketWidth / 2) touchX = basketWidth / 2;
            if (touchX > areaRect.width - basketWidth / 2) touchX = areaRect.width - basketWidth / 2;

            basket.style.left = `${touchX}px`;
        }, { passive: false });

        gameArea.addEventListener('mousemove', function(e) {
            if (!isGameActive) return;
            const areaRect = gameArea.getBoundingClientRect();
            let mouseX = e.clientX - areaRect.left;
            const basketWidth = basket.offsetWidth;
            if (mouseX < basketWidth / 2) mouseX = basketWidth / 2;
            if (mouseX > areaRect.width - basketWidth / 2) mouseX = areaRect.width - basketWidth / 2;
            basket.style.left = `${mouseX}px`;
        });

        catchModal.addEventListener('click', e => {
            if (e.target === catchModal && !isGameActive) catchModal.style.display = 'none';
        });

        function startEnergyTimer() {
            setInterval(() => {
                if (energy < 5) {
                    secondsToRegen--;
                    if (secondsToRegen <= 0) {
                        energy++;
                        secondsToRegen = 1200;
                        updateAllDisplays();
                    }
                    const mins = Math.floor(secondsToRegen / 60);
                    const secs = secondsToRegen % 60;
                    energyTimerDiv.textContent = `+1 через ${mins}:${secs < 10 ? '0' : ''}${secs}`;
                } else {
                    energyTimerDiv.textContent = "Максимум";
                }
            }, 1000);
        }

       
        document.getElementById('quiz-modal').addEventListener('click', e => {
            if (e.target === document.getElementById('quiz-modal')) document.getElementById('quiz-modal').style.display = 'none';
        });
        document.getElementById('wheel-modal').addEventListener('click', e => {
            if (e.target === document.getElementById('wheel-modal') && !isSpinning) document.getElementById('wheel-modal').style.display = 'none';
        });

        window.addEventListener('DOMContentLoaded', () => {
            initBoard();
            startEnergyTimer();
            updateAllDisplays();
            switchTab('home');
        });
    })();
</script>
